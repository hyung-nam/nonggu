        res = col.query(query_texts=[q], n_results=N_RESULTS)
        hits = []
        for i in range(len(res["ids"][0])):
            hits.append((res["documents"][0][i], res["metadatas"][0][i]))

        ctx, refs = build_context_and_refs(hits)

